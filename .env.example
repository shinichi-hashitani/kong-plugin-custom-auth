# =============================================================================
# Kong Konnect (Control Plane) connection settings
# -----------------------------------------------------------------------------
# Copy this file to ".env" and fill in the values from your Konnect org.
#
# In Konnect: Gateway Manager > (your Control Plane) > "+ New Data Plane Node"
# Select "Docker". The generated command shows the endpoints and certificate.
#   - CP / TP endpoints      -> set below
#   - Certificate & key      -> save to ./certs/tls.crt and ./certs/tls.key
# =============================================================================

# Control Plane endpoint (CP outlet). Host only, no scheme, no port.
# Example: abcd1234ef.us.cp.konghq.com
KONNECT_CP_ENDPOINT=

# Telemetry endpoint (TP outlet). Host only, no scheme, no port.
# Example: abcd1234ef.us.tp.konghq.com
KONNECT_TP_ENDPOINT=

# Kong Gateway (data plane) image. Must match the Konnect CP version range.
KONG_IMAGE=kong/kong-gateway:3.14

# Redis connection (used by the custom auth plugins in later phases)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
